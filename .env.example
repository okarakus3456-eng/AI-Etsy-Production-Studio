# ========================================
# AI Etsy Production Studio PRO
# Environment Configuration Template
# ========================================

# ========================================
# Application
# ========================================
APP_NAME=AI Etsy Production Studio PRO
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

# ========================================
# AI Provider
# ========================================
AI_PROVIDER=openai
OPENAI_API_KEY=

# ========================================
# AI Model
# ========================================
VISION_MODEL=
TEXT_MODEL=

# ========================================
# Application Paths
# ========================================
DATA_DIR=data
EXPORT_DIR=exports
LOG_DIR=logs
CACHE_DIR=cache

# ========================================
# Database
# ========================================
DATABASE_URL=sqlite:///data/etsy_studio.db

# ========================================
# Production Settings
# ========================================
MAX_WORKERS=4
MAX_RETRIES=3

# ========================================
# Etsy Configuration
# ========================================
ETSY_SHOP_NAME=

# ========================================
# Currency
# ========================================
DEFAULT_CURRENCY=USD
